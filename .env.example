# ==============================================
# Mada Spot - Variables d'environnement
# ==============================================
# Copier ce fichier en .env et remplir les valeurs

# --- Base de données (Neon PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth ---
NEXTAUTH_SECRET="your-secret-key-here"
CSRF_SECRET="your-csrf-secret-here"

# --- URLs ---
NEXT_PUBLIC_SITE_URL="https://madaspot.mg"
NEXT_PUBLIC_BASE_URL="https://madaspot.mg"

# --- Email ---
RESEND_API_KEY=""
SMTP_API_URL=""
SMTP_FROM="Mada Spot <noreply@madaspot.mg>"
EMAIL_SECRET="your-email-secret-here"
ADMIN_EMAIL="admin@madaspot.mg"

# --- IA / News ---
GROQ_API_KEY=""
GOOGLE_GEMINI_API_KEY=""

# --- Images ---
REPLICATE_API_TOKEN=""
STABILITY_API_KEY=""
PIXABAY_API_KEY=""
PEXELS_API_KEY=""
IMAGE_TRANSFORM_MODE="proxy"
SD_LOCAL_URL="http://127.0.0.1:7860"

# --- Automation / Cron ---
AUTOMATION_API_KEY=""
AUTOMATION_ENABLED="true"
CRON_SECRET=""

# --- Analytics (optionnel) ---
NEXT_PUBLIC_GA_ID=""

# --- Logging ---
LOG_LEVEL="info"

# --- Deployment ---
PORT="3000"
VERCEL_URL=""
RENDER_EXTERNAL_URL=""
