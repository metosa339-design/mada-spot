# Configuration Mada Flash Automation
# Copiez ce fichier vers .env et remplissez les valeurs

# API Claude (Anthropic) - Requis pour la réécriture IA
# Obtenez votre clé sur https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-api03-xxxxx

# API Mada Flash - Pour publier les articles
# L'URL de l'API automation (pas l'admin!)
MADA_FLASH_API_URL=http://localhost:3000/api/automation/articles

# Clé API pour l'authentification
# Cette clé doit correspondre à AUTOMATION_API_KEY dans votre .env Next.js
# Générez une clé unique: openssl rand -hex 32
MADA_FLASH_API_KEY=votre-cle-api-secrete-32-caracteres
