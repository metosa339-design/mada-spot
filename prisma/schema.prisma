  eraId String?
  era   HistoricalEra? @relation(fields: [eraId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eraId])
  @@index([birthYear])
}

