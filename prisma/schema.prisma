// ============================================
// AUDIT TRAIL - LOGS ADMIN
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String? // Admin user ID (null si système)
  action     String // "create", "update", "delete", "approve", "reject", "login", "logout"
  entityType String // "establishment", "provider", "review", "booking", "user", "claim"
  entityId   String? // ID de l'entité concernée
  details    String?  @db.Text // JSON avec les détails de l'action
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@index([entityType, entityId])
}

// ============================================
// MESSAGERIE DIRECTE (CHAT CLIENT-HÔTE)
// ============================================

model Message {
  id       String @id @default(cuid())

  senderId   String
  sender     User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  // Lié à un établissement (contexte de la conversation)
  establishmentId String?
  establishment   Establishment? @relation(fields: [establishmentId], references: [id], onDelete: SetNull)

  content   String  @db.Text
  isRead    Boolean @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
  @@index([establishmentId])
  @@index([createdAt])
}

// ============================================
// RÉPONSES RAPIDES PRÉ-ENREGISTRÉES
// ============================================

model QuickReply {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String // "Confirmation réservation", "Merci pour votre avis"
  content String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================
// TARIFICATION SAISONNIÈRE
// ============================================

model SeasonalPricing {
  id              String        @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  name      String  // "Haute saison", "Basse saison", "Fêtes"
  startDate DateTime
  endDate   DateTime

  // Multiplicateur de prix global (fallback)
  priceMultiplier  Float   @default(1.0)
  // Multiplicateurs par type de prix — JSON: {"Chambre Simple / nuit": 1.1, "Chambre Double / nuit": 1.2}
  priceMultipliers String?

  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([establishmentId])
  @@index([startDate, endDate])
}

// ============================================
// DISPONIBILITÉS (CALENDRIER)
// ============================================

model Availability {
  id              String        @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  date       DateTime
  isBlocked  Boolean @default(false) // Date bloquée manuellement

  // Pour hôtels
  roomsAvailable Int?

  // Pour restaurants
  tablesAvailable Int?

  // Pour attractions
  spotsAvailable Int?

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([establishmentId, date])
  @@index([establishmentId, date])
}

// ============================================
// DOCUMENTS DE VÉRIFICATION
// ============================================

model VerificationDocument {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Type de document
  documentType String // "nif", "stat", "business_license", "id_card"
  documentUrl  String

  status     VerificationStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?
  note       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================
// STATISTIQUES DE VUES (ANALYTICS)
// ============================================

model EstablishmentView {
  id              String @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)

  // Tracking
  visitorId String? // Anonyme cookie-based
  userId    String? // Si connecté
  source    String? // "search", "direct", "map", "featured"

  createdAt DateTime @default(now())

  @@index([establishmentId])
  @@index([establishmentId, createdAt])
  @@index([createdAt])
}

// ============================================
// CALENDRIER D'ÉVÉNEMENTS
// ============================================

enum EventCategory {
  FESTIVAL
  CULTURAL
  SPORT
  NATURE
  MARKET
  OTHER
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EventType {
  EVENT
  PROMOTION
  ADVERTISEMENT
}

enum EventBadge {
  NOUVEAU
  PROMO
  EXCLUSIF
  OFFICIEL
}

enum TargetAudience {
  ALL
  TRAVELERS
  PROVIDERS
}

model Event {
  id                String          @id @default(cuid())
  title             String
  slug              String          @unique
  description       String?         @db.Text
  startDate         DateTime
  endDate           DateTime?
  location          String?
  city              String
  region            String?
  category          EventCategory
  coverImage        String?
  organizer         String?
  isRecurring       Boolean         @default(false)
  recurrenceRule    String?
  establishmentId   String?
  establishment     Establishment?  @relation(fields: [establishmentId], references: [id], onDelete: SetNull)
  submittedByUserId String?
  status            EventStatus     @default(PENDING)

  // Event & Promo Advertising fields
  eventType         EventType       @default(EVENT)
  badge             EventBadge?
  isPinned          Boolean         @default(false)
  targetAudience    TargetAudience  @default(ALL)
  ctaLabel          String?
  ctaLink           String?

  // Régie Pub & Monetization fields
  isPromotion       Boolean         @default(false)
  priorityScore     Int             @default(0)        // Higher = shown first, VIP card format
  linkedProductType String?                             // "LOCATION_VOITURE", "RESTAURANT", "HOTEL", "ATTRACTION"
  linkedProductId   String?                             // ID of linked feature/product

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([startDate])
  @@index([city])
  @@index([category])
  @@index([status, startDate])
  @@index([isPinned, status])
  @@index([priorityScore])
}

// ============================================
// PRÉSENCE UTILISATEUR (en ligne, saisie)
// ============================================

model UserPresence {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isOnline   Boolean  @default(false)
  lastSeenAt DateTime @default(now())

  // Typing state
  typingThreadId String?
  typingAt       DateTime?

  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isOnline])
}

// ============================================
// SYSTÈME PUBLICITAIRE
// ============================================

model Advertisement {
  id       String @id @default(cuid())
  name     String // Libellé interne

  // Placement
  position String // top_banner | sidebar_top | sidebar_middle | sidebar_bottom | mobile_banner | mobile_square
  format   String @default("auto") // auto | 300x300 | 300x250 | 300x600 | 320x100

  // Contenu
  imageUrl String
  linkUrl  String?
  altText  String?

  // Contrôle
  isActive Boolean @default(true)
  priority Int     @default(0) // Higher = shown first

  // Planification
  startDate DateTime?
  endDate   DateTime?

  // Métriques dénormalisées
  impressions Int @default(0)
  clicks      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position, isActive])
  @@index([isActive, startDate, endDate])
}

// ============================================
// ALERTES MÉTÉO
// ============================================

model WeatherAlert {
  id      String @id @default(cuid())
  type    String // cyclone, flood, storm, heatwave
  level   String // green, yellow, orange, red
  title   String
  message String @db.Text
  regions String? // Comma-separated: "Nosy Be, Antananarivo"

  startDate DateTime
  endDate   DateTime?
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, startDate, endDate])
  @@index([level])
}

// ============================================
// RESSOURCES MINIÈRES
// ============================================

model MiningResource {
  id       String  @id @default(cuid())
  name     String
  nameEn   String?
  nameMg   String?
  slug     String  @unique
  type     String  // precious_stone, mineral, metal, energy
  subType  String? // sapphire, ruby, nickel, graphite, etc.

  description         String?  @db.Text
  region              String?
  locations           String?  // JSON array: [{name, coordinates}]
  discoveryYear       Int?
  exploitationStart   Int?
  productionVolume    String?
  worldRank           Int?
  percentWorld        Float?
  operators           String?  // JSON array of operator names
  environmentalImpact String?  @db.Text

  imageUrl   String?
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([slug])
  @@index([isFeatured])
}

// ============================================
// OTP CODES (Vérification Email)
// ============================================

model OTPCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String    // 6 digits
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([code, userId])
  @@index([expiresAt])
}

// ============================================
// ANTI-CONTOURNEMENT (Scan des messages)
// ============================================

model MessageScanAlert {
  id          String          @id @default(cuid())
  messageId   String
  senderId    String
  receiverId  String
  content     String          @db.Text
  matchType   String          // "phone", "whatsapp", "email"
  matchValue  String          // La valeur détectée
  status      ScanAlertStatus @default(PENDING)
  reviewedBy  String?
  actionTaken String?         // "masked", "suspended", "dismissed"
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([senderId])
  @@index([createdAt])
}

// ============================================
// CLICK TRACKING (Appels, WhatsApp, Email sortants)
// ============================================

model OutboundClick {
  id              String        @id @default(cuid())
  establishmentId String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  clickType       String        // "phone", "whatsapp", "email", "website", "facebook", "instagram"
  userId          String?
  sessionId       String?
  createdAt       DateTime      @default(now())

  @@index([establishmentId])
  @@index([clickType])
  @@index([createdAt])
  @@index([establishmentId, createdAt])
}

// ============================================
// SUPPORT TICKETS
// ============================================

model SupportTicket {
  id          String         @id @default(cuid())
  userId      String?
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String
  subject     String
  description String         @db.Text
  category    String         // "bug", "billing", "feature", "complaint", "other"
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  assignedTo  String?
  reference   String         @unique // "TK-XXXXXX"

  replies   TicketReply[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([reference])
  @@index([createdAt])
}

model TicketReply {
  id         String @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  authorType String // "user", "admin", "system"
  content    String @db.Text

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

// ============================================
// SEO SEARCH LOGS
// ============================================

model SearchLog {
  id          String   @id @default(cuid())
  query       String
  userId      String?
  resultCount Int      @default(0)
  filters     String?  // JSON: { type, city, ... }
  createdAt   DateTime @default(now())

  @@index([query])
  @@index([createdAt])
  @@index([resultCount])
}

// ============================================
// GAMIFICATION BADGES
// ============================================

model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     BadgeType
  awardedAt DateTime  @default(now())

  @@unique([userId, badge])
  @@index([userId])
}
